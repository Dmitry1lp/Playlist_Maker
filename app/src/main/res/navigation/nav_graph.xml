<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mediaFragment2">

    <fragment
        android:id="@+id/searchFragment2"
        android:name="com.practicum.playlistmaker.search.ui.SearchFragment"
        android:label="fragment_search"
        tools:layout="@layout/fragment_search" >
        <action
            android:id="@+id/action_searchFragment2_to_mediaFragment2"
            app:destination="@id/mediaFragment2" />
        <action
            android:id="@+id/action_searchFragment2_to_playerFragment"
            app:destination="@id/playerFragment" />
    </fragment>
    <fragment
        android:id="@+id/mediaFragment2"
        android:name="com.practicum.playlistmaker.media.ui.media.MediaFragment"
        android:label="fragment_media"
        tools:layout="@layout/fragment_media" >
        <action
            android:id="@+id/action_mediaFragment2_to_settingsFragment2"
            app:destination="@id/settingsFragment2" />
        <action
            android:id="@+id/action_mediaFragment2_to_playerFragment"
            app:destination="@id/playerFragment" />
        <action
            android:id="@+id/action_mediaFragment2_to_favoritesInfoFragment"
            app:destination="@id/favoritesInfoFragment" />
        <action
            android:id="@+id/action_mediaFragment2_to_playlistFragment"
            app:destination="@id/playlistFragment" />
    </fragment>
    <fragment
        android:id="@+id/settingsFragment2"
        android:name="com.practicum.playlistmaker.settings.ui.SettingsFragment"
        android:label="fragment_settings"
        tools:layout="@layout/fragment_settings" />
    <fragment
        android:id="@+id/playerFragment"
        android:name="com.practicum.playlistmaker.player.ui.PlayerFragment"
        android:label="fragment_audioplayer"
        tools:layout="@layout/fragment_audioplayer" >
        <action
            android:id="@+id/action_playerFragment_to_favoritesInfoFragment"
            app:destination="@id/favoritesInfoFragment" />
    </fragment>
    <fragment
        android:id="@+id/favoritesInfoFragment"
        android:name="com.practicum.playlistmaker.media.ui.favorites.FavoritesInfoFragment"
        android:label="FavoritesInfoFragment" />
    <fragment
        android:id="@+id/playlistsFragment"
        android:name="com.practicum.playlistmaker.media.ui.playlist.PlaylistsFragment"
        android:label="PlaylistsFragment" />
    <fragment
        android:id="@+id/playlistFragment"
        android:name="com.practicum.playlistmaker.media.ui.playlist.PlaylistFragment"
        android:label="PlaylistFragment" >
        <action
            android:id="@+id/action_playlistFragment_to_playerFragment"
            app:destination="@id/playerFragment" />
        <action
            android:id="@+id/action_playlistFragment_to_editPlaylistFragment"
            app:destination="@id/editPlaylistFragment">
            <argument
                android:name="playlistId"
                app:argType="long"
                 />
        </action>
    </fragment>
    <fragment
        android:id="@+id/editPlaylistFragment"
        android:name="com.practicum.playlistmaker.media.ui.EditPlaylistFragment"
        android:label="EditPlaylistFragment">

        <argument
            android:name="playlistId"
            app:argType="long" />
    </fragment>
</navigation>