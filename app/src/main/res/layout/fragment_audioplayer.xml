<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorOnPrimary"
    tools:context="com.practicum.playlistmaker.player.ui.PlayerFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorOnPrimary"
        android:paddingBottom="@dimen/radiusSize_16dp"
        tools:context="com.practicum.playlistmaker.player.ui.PlayerFragment">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_leftBorder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="@dimen/radiusSize_16dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_rightBorder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="@dimen/radiusSize_16dp" />

        <!-- Назад-->
        <ImageButton
            android:id="@+id/iv_back_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/back_button"
            android:background="?attr/colorOnPrimary"
            app:tint="?attr/colorPrimaryVariant"
            android:src="@drawable/light_modesetting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Country -->
        <TextView
            android:id="@+id/tv_country_label"
            style="@style/AudioTextView1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radiusSize_16dp"
            android:layout_marginBottom="@dimen/search_not_internet_24dp"
            android:paddingTop="@dimen/medium_padding"
            android:paddingBottom="@dimen/medium_padding"
            android:text="@string/country"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_country"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_country"
            style="@style/AudioTextView2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radiusSize_16dp"
            android:layout_marginEnd="@dimen/radiusSize_16dp"
            android:paddingTop="@dimen/medium_padding"
            android:paddingBottom="@dimen/medium_padding"
            android:text="@string/country"
            app:layout_constraintBottom_toBottomOf="@id/tv_country_label"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="2"
            app:layout_constraintStart_toEndOf="@id/tv_country_label"
            app:layout_constraintTop_toTopOf="@id/tv_country_label" />

        <!-- Genre -->
        <TextView
            android:id="@+id/tv_genre_label"
            style="@style/AudioTextView1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radiusSize_16dp"
            android:paddingTop="@dimen/medium_padding"
            android:paddingBottom="@dimen/medium_padding"
            android:text="@string/genre"
            app:layout_constraintBottom_toTopOf="@id/tv_country_label"
            app:layout_constraintEnd_toStartOf="@id/tv_genre"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_genre"
            style="@style/AudioTextView2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radiusSize_16dp"
            android:layout_marginEnd="@dimen/radiusSize_16dp"
            android:paddingTop="@dimen/medium_padding"
            android:paddingBottom="@dimen/medium_padding"
            android:text="@string/genre"
            app:layout_constraintBottom_toBottomOf="@id/tv_genre_label"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="2"
            app:layout_constraintStart_toEndOf="@id/tv_genre_label"
            app:layout_constraintTop_toTopOf="@id/tv_genre_label" />

        <!-- Year -->
        <TextView
            android:id="@+id/tv_year_label"
            style="@style/AudioTextView1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radiusSize_16dp"
            android:paddingTop="@dimen/medium_padding"
            android:paddingBottom="@dimen/medium_padding"
            android:text="@string/year"
            app:layout_constraintBottom_toTopOf="@id/tv_genre_label"
            app:layout_constraintEnd_toStartOf="@id/tv_year"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_year"
            style="@style/AudioTextView2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radiusSize_16dp"
            android:layout_marginEnd="@dimen/radiusSize_16dp"
            android:paddingTop="@dimen/medium_padding"
            android:paddingBottom="@dimen/medium_padding"
            android:text="@string/year"
            app:layout_constraintBottom_toBottomOf="@id/tv_year_label"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="2"
            app:layout_constraintStart_toEndOf="@id/tv_year_label"
            app:layout_constraintTop_toTopOf="@id/tv_year_label" />

        <!-- Album -->
        <TextView
            android:id="@+id/tv_album_label"
            style="@style/AudioTextView1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radiusSize_16dp"
            android:paddingTop="@dimen/medium_padding"
            android:paddingBottom="@dimen/medium_padding"
            android:text="@string/album"
            app:layout_constraintBottom_toTopOf="@id/tv_year_label"
            app:layout_constraintEnd_toStartOf="@id/tv_album"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_album"
            style="@style/AudioTextView2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radiusSize_16dp"
            android:layout_marginEnd="@dimen/radiusSize_16dp"
            android:paddingTop="@dimen/medium_padding"
            android:paddingBottom="@dimen/medium_padding"
            android:text="@string/album"
            app:layout_constraintBottom_toBottomOf="@id/tv_album_label"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="2"
            app:layout_constraintStart_toEndOf="@id/tv_album_label"
            app:layout_constraintTop_toTopOf="@id/tv_album_label" />

        <!-- Duration -->
        <TextView
            android:id="@+id/tv_duration_label"
            style="@style/AudioTextView1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radiusSize_16dp"
            android:text="@string/duration"
            android:paddingTop="@dimen/medium_padding"
            android:paddingBottom="@dimen/medium_padding"
            app:layout_constraintBottom_toTopOf="@id/tv_album_label"
            app:layout_constraintEnd_toStartOf="@id/tv_duration"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_duration"
            style="@style/AudioTextView2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radiusSize_16dp"
            android:layout_marginEnd="@dimen/radiusSize_16dp"
            android:paddingTop="@dimen/medium_padding"
            android:paddingBottom="@dimen/medium_padding"
            android:text="@string/duration"
            app:layout_constraintBottom_toBottomOf="@id/tv_duration_label"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="2"
            app:layout_constraintStart_toEndOf="@id/tv_duration_label"
            app:layout_constraintTop_toTopOf="@id/tv_duration_label" />

        <!--Indicator-->
        <TextView
            android:id="@+id/tv_time_indicator"
            style="@style/TextViewTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/tv_time_indicator"
            android:layout_weight="1"
            android:text="@string/time"
            app:layout_constraintBottom_toTopOf="@id/tv_duration_label"
            app:layout_constraintEnd_toEndOf="@id/gl_rightBorder"
            app:layout_constraintStart_toStartOf="@id/gl_leftBorder" />

        <!-- Spread Button-->
        <ImageButton
            android:id="@+id/ib_add_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/medium_padding"
            android:background="?attr/colorOnPrimary"
            android:src="@drawable/add_button"
            app:layout_constraintBottom_toBottomOf="@+id/ib_play_button"
            app:layout_constraintEnd_toStartOf="@id/ib_play_button"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="@id/gl_leftBorder"
            app:layout_constraintTop_toTopOf="@+id/ib_play_button" />

        <ImageButton
            android:id="@+id/ib_play_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/edit_search"
            android:background="?attr/colorOnPrimary"
            android:src="@drawable/play_button"
            app:layout_constraintBottom_toTopOf="@+id/tv_time_indicator"
            app:layout_constraintEnd_toStartOf="@+id/ib_like_button"
            app:layout_constraintStart_toEndOf="@+id/ib_add_button" />

        <ImageButton
            android:id="@+id/ib_like_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/medium_padding"
            android:background="?attr/colorOnPrimary"
            android:src="@drawable/like_button"
            app:layout_constraintBottom_toBottomOf="@id/ib_play_button"
            app:layout_constraintEnd_toStartOf="@id/gl_rightBorder"
            app:layout_constraintStart_toEndOf="@id/ib_play_button"
            app:layout_constraintTop_toTopOf="@id/ib_play_button" />

        <ImageView
            android:id="@+id/iv_album"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/album_padding"
            android:layout_marginBottom="@dimen/search_not_internet_24dp"
            android:background="?attr/colorOnPrimary"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder"
            app:layout_constraintBottom_toTopOf="@id/tv_trackName"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="@id/gl_rightBorder"
            app:layout_constraintStart_toStartOf="@id/gl_leftBorder"
            app:layout_constraintTop_toBottomOf="@id/iv_back_button" />

        <TextView
            android:id="@+id/tv_groupName"
            style="@style/TextViewTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/artist"
            app:layout_constraintBottom_toTopOf="@id/ib_play_button"
            app:layout_constraintStart_toStartOf="@id/ib_add_button"
            app:layout_constraintTop_toBottomOf="@id/iv_album" />

        <TextView
            android:id="@+id/tv_trackName"
            style="@style/TextViewTrack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/edit_search"
            android:text="@string/trackName"
            app:layout_constraintBottom_toTopOf="@id/tv_groupName"
            app:layout_constraintStart_toStartOf="@id/tv_groupName" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/standart_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_rounded"
        android:padding="16dp"
        app:behavior_peekHeight="@dimen/bottom_sheet_505dp"
        app:behavior_hideable="true"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <TextView
            android:id="@+id/tv_add_to_playlist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_in_playlist"
            style="@style/FavoriteAdd"
            android:paddingBottom="@dimen/radiusSize_16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mb_new_playlist"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/refresh_height"
            android:text="@string/new_playlist"
            android:background="@drawable/refresh_button"
            app:layout_constraintTop_toBottomOf="@id/tv_add_to_playlist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/RefreshIcon" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_audio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="@dimen/search_not_internet_24dp"
            app:layout_constraintTop_toBottomOf="@+id/mb_new_playlist"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>